PORT=3000

# test or production
TELEBIRR_ENV=test

# Optional. Leave empty to use the official test/production URL for TELEBIRR_ENV.
TELEBIRR_BASE_URL=

# Get these from https://developer.ethiotelecom.et/
TELEBIRR_FABRIC_APP_ID=your_fabric_app_id
TELEBIRR_APP_SECRET=your_app_secret
TELEBIRR_MERCHANT_APP_ID=your_merchant_app_id
TELEBIRR_SHORT_CODE=your_business_short_code

# Recommended: keep the private key in a local file that is never committed.
TELEBIRR_PRIVATE_KEY_PATH=./keys/private_key.pem

# Optional alternative for deployment platforms:
# TELEBIRR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Your public backend callback URL. Telebirr calls this after payment.
TELEBIRR_NOTIFY_URL=https://yourdomain.com/api/telebirr/notify

# Optional browser/deep-link return URL if your Telebirr contract needs it.
TELEBIRR_REDIRECT_URL=

TELEBIRR_TIMEOUT=120m
TELEBIRR_PAYEE_TYPE=3000

# Testbed certificates may require this on some local machines.
# Keep true in production.
TELEBIRR_VERIFY_SSL=true
