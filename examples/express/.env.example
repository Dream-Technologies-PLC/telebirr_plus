PORT=3000

# test for Telebirr testbed, production for live payments.
TELEBIRR_ENV=test

# Leave empty unless Telebirr gave you a custom gateway URL.
TELEBIRR_BASE_URL=

# Get these from https://developer.ethiotelecom.et/
TELEBIRR_FABRIC_APP_ID=your_fabric_app_id
TELEBIRR_APP_SECRET=your_app_secret
TELEBIRR_MERCHANT_APP_ID=your_merchant_app_id
TELEBIRR_SHORT_CODE=your_business_short_code

# Store the private key in a local file that is never committed.
TELEBIRR_PRIVATE_KEY_PATH=./keys/private_key.pem

# Telebirr calls this after payment. For real testing, use a public HTTPS URL.
TELEBIRR_NOTIFY_URL=https://yourdomain.com/api/telebirr/notify

TELEBIRR_TIMEOUT=120m
TELEBIRR_PAYEE_TYPE=3000

# Some Telebirr testbed certificates fail on local machines.
# Keep true in production. Use false only for local testbed debugging.
TELEBIRR_VERIFY_SSL=true
